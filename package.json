{
  "name": "dolphinspired.github.io",
  "version": "1.0.0",
  "description": "Playground for fun experiments 🧪",
  "homepage": "https://nuffle.me",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dolphinspired/dolphinspired.github.io.git"
  },
  "scripts": {
    "build": "cross-env TEMP=./tmp parcel build 'src/**/*.html'",
    "clean": "rm -rf .parcel-cache .wrangler dist tmp",
    "login": "wrangler login",
    "predeploy": "npm run clean && npm run build",
    "deploy": "wrangler pages deploy dist/ --project-name=nuffle-me",
    "serve": "cross-env TEMP=./tmp parcel 'src/**/*.html'"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "parcel": "^2.15.4",
    "typescript": "^5.9.2",
    "wrangler": "^4.75.0"
  }
}
